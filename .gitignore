# ============================================================================
# .gitignore ÚNICO do projeto (raiz). Padrões sem barra inicial pegam também o
# que está dentro de frontend/ e studio/. NÃO criar .gitignore em subpastas.
#
# A pasta de agentes (.agents/ — Antigravity Kit) NÃO entra aqui: ela é
# excluída LOCALMENTE via .git/info/exclude para não quebrar a indexação dos
# workflows/slash-commands das IDEs. Ver README → "Regras de IA".
# ============================================================================

# Dependências
node_modules/

# Builds / saída
dist/
dist-ssr/
build/

# Variáveis de ambiente e arquivos locais
.env
.env.*
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Caches de ferramentas
.cache/
.vite/
.eslintcache

# Sistema operacional
.DS_Store
Thumbs.db

# Editores / IDEs
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
